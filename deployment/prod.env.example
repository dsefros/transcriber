# Copy to deployment/prod.env and edit before first deployment.
COMPOSE_PROJECT_NAME=transcriber

# GHCR image coordinates
IMAGE_REPOSITORY=ghcr.io/<owner>
IMAGE_NAME=<repo>
IMAGE_TAG=prod-latest

# Runtime config
POSTGRES_DB=transcriber
POSTGRES_USER=transcriber
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://transcriber:change-me@postgres:5432/transcriber
ACTIVE_MODEL_PROFILE=
HF_TOKEN=
OLLAMA_HOST=

# Host mount points
MODELS_CONFIG_PATH=./models.yaml
INPUT_DIR=./runtime/input
OUTPUT_DIR=./runtime/output
LOG_DIR=./runtime/logs
PGDATA_DIR=./runtime/postgres

# Default production validation job source (inside INPUT_DIR)
JOB_SOURCE_PATH=/data/input/segments.sample.json
