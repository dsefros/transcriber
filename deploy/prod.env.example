# Runtime home on server
TRANSCRIBER_HOME=/opt/transcriber
COMPOSE_PROJECT_NAME=transcriber

# GHCR image coordinates (images are built in GitHub Actions, not on server)
IMAGE_REPOSITORY=ghcr.io/<owner>
IMAGE_NAME=<repo>
IMAGE_TAG=prod-latest

# Runtime config
POSTGRES_DB=transcriber
POSTGRES_USER=transcriber
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://transcriber:change-me@postgres:5432/transcriber
ACTIVE_MODEL_PROFILE=
HF_TOKEN=
OLLAMA_HOST=

# Fixed runtime mount points
MODELS_CONFIG_PATH=/opt/transcriber/models.yaml
INPUT_DIR=/opt/transcriber/runtime/input
OUTPUT_DIR=/opt/transcriber/runtime/output
LOG_DIR=/opt/transcriber/runtime/logs
PGDATA_DIR=/opt/transcriber/runtime/postgres

# Default validation source path inside container
JOB_SOURCE_PATH=/data/input/segments.sample.json
